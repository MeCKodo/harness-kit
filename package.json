{
  "name": "@erzhe/harness-kit",
  "version": "0.6.0",
  "type": "module",
  "description": "AI-friendly repo harness: a manifest.yaml single source of truth that generates AGENTS.md / CLAUDE.md / Cursor rules and enforces invariants, contracts and drift via `harness-kit verify`.",
  "keywords": [
    "ai",
    "agent",
    "agents.md",
    "cli",
    "harness",
    "scaffold",
    "manifest",
    "cursor",
    "claude"
  ],
  "homepage": "https://github.com/MeCKodo/harness-kit#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MeCKodo/harness-kit.git"
  },
  "bugs": {
    "url": "https://github.com/MeCKodo/harness-kit/issues"
  },
  "author": "MeCKodo (二哲) <https://erzhe.me/>",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "harness-kit": "dist/harness-kit.cjs"
  },
  "files": [
    "dist",
    "skills",
    "SPEC-v0.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "harness": "tsx src/cli.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --format=cjs --target=node18 --log-override:empty-import-meta=silent --outfile=dist/harness-kit.cjs && chmod +x dist/harness-kit.cjs",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "test:repos": "bash scripts/regression.sh",
    "prepare": "pnpm build"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "picomatch": "^4.0.2",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/picomatch": "^4.0.2",
    "esbuild": "^0.28.1",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3"
  }
}
